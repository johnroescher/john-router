# Database
POSTGRES_USER=johnrouter
POSTGRES_PASSWORD=johnrouter_dev
POSTGRES_DB=johnrouter
DATABASE_URL=postgresql://johnrouter:johnrouter_dev@localhost:5432/johnrouter

# Redis
REDIS_URL=redis://localhost:6379/0

# API Keys (REQUIRED)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Routing Service (at least one required)
# OpenRouteService API - get free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# Map Tiles (optional but recommended)
# MapTiler - get free key at https://www.maptiler.com/cloud/
MAPTILER_KEY=your_maptiler_key_here
# OR Mapbox - get token at https://www.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Application
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
CORS_ORIGINS=http://localhost:3000

# Elevation Data (optional)
# OpenTopoData self-hosted or use free public instance
ELEVATION_API_URL=https://api.opentopodata.org/v1/

# Feature Flags
ENABLE_RESEARCH_SERVICE=true
ENABLE_SPEECH_INPUT=false
USE_SELF_HOSTED_ROUTING=false
